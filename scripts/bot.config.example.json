{
  "symbols": ["BITSTAMP:BTCUSD", "COINBASE:ETHUSD"],
  "timeframe": "240",
  "poll_seconds": 60,

  "ema_length": 20,
  "rsi_length": 14,
  "rsi_long_max": 60,
  "rsi_short_min": 40,

  "use_trend_filter": true,
  "trend_ema_length": 50,
  "use_volume_filter": true,
  "volume_ma_length": 20,

  "atr_length": 14,
  "atr_stop_mult": 1.5,
  "risk_reward": 2.0,

  "risk_per_trade_pct": 0.5,
  "qty_per_trade": 0.001,
  "max_qty": 0.05,
  "min_qty": 0.0001,

  "max_open_positions": 2,
  "stop_after_consecutive_losses": 2,
  "max_daily_loss_pct": 3.0,

  "manage_positions": true,
  "be_at_r": 1.0,
  "trail_enabled": false,
  "trail_atr_mult": 2.0,

  "session_filter": { "enabled": false, "timezone": "America/New_York", "start": "09:30", "end": "16:00", "skip_open_minutes": 15 },
  "cooldown_seconds": 900,
  "max_trades_per_day": 10,

  "status_enabled": true,
  "status_path": "/status",
  "notify": {
    "telegram": { "enabled": false, "bot_token": "", "chat_id": "" },
    "discord": { "enabled": false, "webhook_url": "" }
  },
  "journal_file": "scripts/bot.trades.csv",

  "allow_short": true,
  "dry_run": true,

  "signal_source": "internal",
  "combine_rule": "all_agree",
  "fpu_study_filter": "MAX",
  "fpu_bull": 65,
  "fpu_bear": 35,
  "fpu_regime_filter": true,

  "poll_enabled": true,
  "webhook_enabled": false,
  "webhook_host": "127.0.0.1",
  "webhook_port": 8080,
  "webhook_path": "/tv-webhook",
  "webhook_secret": "",
  "webhook_symbol_map": {
    "BTCUSD": "BITSTAMP:BTCUSD",
    "ETHUSD": "COINBASE:ETHUSD",
    "SOLUSD": "COINBASE:SOLUSD"
  },

  "state_file": "scripts/bot.state.json",
  "log_file": "scripts/bot.log"
